# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.

# ── Database ──────────────────────────────────────────────────────────────────
# Override the default DB path from config/default.toml
# WOW_FORECASTER_DB_PATH=data/db/wow_forecaster.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Override log level: DEBUG, INFO, WARNING, ERROR
# WOW_FORECASTER_LOG_LEVEL=DEBUG

# ── Blizzard Battle.net API ───────────────────────────────────────────────────
# BLIZZARD_CLIENT_ID=your_client_id_here
# BLIZZARD_CLIENT_SECRET=your_client_secret_here
# BLIZZARD_REGION=us

# ── Durable-table backup to R2 (see docs/db-backup.md) ───────────────────────
# Only needed on the machine that runs backup-durable-db --upload. Point at a
# separate, private R2 bucket (not the cloud-capture snapshots bucket). Uploading
# needs boto3: pip install -e ".[cloud]".
# BACKUP_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# BACKUP_S3_BUCKET=wow-forecaster-backups
# BACKUP_S3_ACCESS_KEY_ID=your_scoped_token_key
# BACKUP_S3_SECRET_ACCESS_KEY=your_scoped_token_secret
# BACKUP_S3_REGION=auto

# ── Future: News / Wowhead patch notes scraping ──────────────────────────────
# NEWS_SCRAPE_USER_AGENT=wow-economy-forecaster/0.1.0
