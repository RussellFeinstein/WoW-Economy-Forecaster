# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment / secrets
.env
*.env.local

# Data files (local only - tracked via .gitkeep)
# Snapshot rules use **/ because sources write dated subdirectories
# (blizzard_api/YYYY/MM/DD/...); a single * misses them (issue #9).
data/raw/snapshots/**/*.parquet
data/raw/snapshots/**/*.json
data/raw/snapshots/**/*.csv
data/raw/events/*.csv
data/raw/events/*.json
data/processed/**/*.parquet
data/processed/**/*.json
data/processed/**/*.csv
data/outputs/**/*.parquet
data/outputs/**/*.json
data/outputs/**/*.csv
data/outputs/charts/
data/outputs/model_artifacts/
data/outputs/backups/
data/db/*.db
data/db/*.db-wal
data/db/*.db-shm
data/db/.*.lock
# Learning-track review state. Personal progress, deliberately kept out of the
# product database so it never lands in a durable backup or the M3 warehouse.
data/learn/
data/*.db
data/*.db-wal
data/*.db-shm
data/logs/*.log
logs/

# Claude Code (local permission settings — not shared across machines)
.claude/

# Wrangler build/state cache for the cloud-capture trigger Worker
cloud-trigger/.wrangler/

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing / Coverage
.coverage
.pytest_cache/
htmlcov/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/
# Notebooks in notebooks/ are committed for portfolio display.
# Exclude generated data used by notebooks.
notebooks/data/
